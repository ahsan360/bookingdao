DATABASE_URL="file:./dev.db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV="development"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# SSL Commerz Configuration
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_SANDBOX=true
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com

# Slot Lock Configuration
SLOT_LOCK_TTL_SECONDS=600

# Encryption Key (generate a random 32-byte hex string)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-change-in-production
