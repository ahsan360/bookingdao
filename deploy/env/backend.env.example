# ─── Backend Production Environment ──────────────────────────
NODE_ENV=production
PORT=5000

# Database (RDS PostgreSQL free tier)
DATABASE_URL="postgresql://bookease:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/bookease?schema=public"

# JWT
JWT_SECRET="generate-a-strong-random-secret-here"
JWT_EXPIRES_IN="7d"

# CORS - allow main domain + all subdomains
CORS_ORIGINS="https://bookease.com,https://*.bookease.com"

# SSLCommerz (payment gateway)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWD=""
SSLCOMMERZ_SANDBOX=false

# App domain (used for building tenant URLs)
APP_DOMAIN="bookease.com"
APP_PROTOCOL="https"
